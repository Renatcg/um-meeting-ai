LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/um_meeting_ai
APP_JWT_SECRET=replace-me-with-a-long-random-string

# Jarvis agent
API_URL=http://localhost:8000
AGENT_API_KEY=replace-me
OPENAI_API_KEY=replace-me
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_MEDIA_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_INTERVENTION_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o-mini
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=ash
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
JARVIS_AGENT_NAME=jarvis
JARVIS_DISPLAY_NAME=Jarvis
JARVIS_VAD_THRESHOLD=0.72
JARVIS_VAD_PREFIX_PADDING_MS=300
JARVIS_VAD_SILENCE_DURATION_MS=900
JARVIS_MIN_TRANSCRIPT_CHARS=8
JARVIS_MIN_TRANSCRIPT_WORDS=2
COPILOT_AUTO_DISPATCH=true

# Lead confirmation email
RESEND_API_KEY=replace-me
RESEND_FROM_EMAIL=contato@coevolabs.com
RESEND_FROM_NAME=Coevo Labs

# Google Calendar integration
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/integrations/google-calendar/callback
GOOGLE_CALENDAR_TIME_ZONE=America/Sao_Paulo

# LiveKit Egress recordings to S3/R2
RECORDINGS_ENABLED=false
RECORDING_STORAGE_PROVIDER=r2
RECORDING_S3_BUCKET=replace-me
RECORDING_S3_REGION=auto
RECORDING_S3_ACCESS_KEY_ID=replace-me
RECORDING_S3_SECRET_ACCESS_KEY=replace-me
RECORDING_S3_ENDPOINT=https://account-id.r2.cloudflarestorage.com
RECORDING_S3_FORCE_PATH_STYLE=true
RECORDING_PUBLIC_BASE_URL=
RECORDING_OBJECT_PREFIX=recordings

# WhatsApp via Evo API
EVO_API_ENABLED=false
EVO_API_BASE_URL=https://your-evo-api.example.com
EVO_API_KEY=replace-me
EVO_API_INSTANCE=replace-me
# Optional. Leave empty when using only WHATSAPP_ALLOWED_PHONES.
EVO_API_WEBHOOK_SECRET=
WHATSAPP_ALLOWED_PHONES=5511999999999,5511888888888
