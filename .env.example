LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/um_meeting_ai
APP_JWT_SECRET=replace-me-with-a-long-random-string

# Jarvis agent
API_URL=http://localhost:8000
AGENT_API_KEY=replace-me
OPENAI_API_KEY=replace-me
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_MEDIA_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_INTERVENTION_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o-mini
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=ash
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
JARVIS_AGENT_NAME=jarvis
JARVIS_DISPLAY_NAME=Jarvis
JARVIS_VAD_THRESHOLD=0.78
JARVIS_VAD_PREFIX_PADDING_MS=250
JARVIS_VAD_SILENCE_DURATION_MS=950
JARVIS_MIN_TRANSCRIPT_CHARS=12
JARVIS_MIN_TRANSCRIPT_WORDS=3
AGENT_ORB_VIDEO_ENABLED=true
AGENT_ORB_VIDEO_WIDTH=360
AGENT_ORB_VIDEO_HEIGHT=240
AGENT_ORB_VIDEO_FPS=8
COPILOT_AUTO_DISPATCH=true

# Lead confirmation email
RESEND_API_KEY=replace-me
RESEND_FROM_EMAIL=contato@coevolabs.com
RESEND_FROM_NAME=Coevo Labs

# Google Calendar integration
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/integrations/google-calendar/callback
GOOGLE_CALENDAR_TIME_ZONE=America/Sao_Paulo

# LiveKit Egress recordings to S3/R2
RECORDINGS_ENABLED=false
RECORDING_STORAGE_PROVIDER=r2
RECORDING_S3_BUCKET=replace-me
RECORDING_S3_REGION=auto
RECORDING_S3_ACCESS_KEY_ID=replace-me
RECORDING_S3_SECRET_ACCESS_KEY=replace-me
RECORDING_S3_ENDPOINT=https://account-id.r2.cloudflarestorage.com
RECORDING_S3_FORCE_PATH_STYLE=true
RECORDING_PUBLIC_BASE_URL=
RECORDING_OBJECT_PREFIX=recordings
MEETING_CLEANUP_ENABLED=true
MEETING_CLEANUP_INTERVAL_SECONDS=300

# WhatsApp via Evo API
EVO_API_ENABLED=false
EVO_API_BASE_URL=https://your-evo-api.example.com
EVO_API_KEY=replace-me
EVO_API_INSTANCE=replace-me
# Optional. Leave empty when using only WHATSAPP_ALLOWED_PHONES.
EVO_API_WEBHOOK_SECRET=
WHATSAPP_ALLOWED_PHONES=5511999999999,5511888888888
WHATSAPP_SEND_AUDIO_REPLIES=true
WHATSAPP_AUDIO_VOICE=marin
WHATSAPP_TTS_MODEL=gpt-4o-mini-tts
WHATSAPP_GROUP_ENABLED=true
WHATSAPP_GROUP_SUMMARY_LIMIT=80

# Smart speaker voice channel
# Use a dedicated token in production. If empty, the API falls back to AGENT_API_KEY.
SMART_SPEAKER_API_KEY=replace-me
SMART_SPEAKER_TTS_MODEL=gpt-4o-mini-tts
SMART_SPEAKER_DEFAULT_MIMETYPE=audio/wav

# Optional parallel path: Coevo as an MCP service for the original XiaoZhi agent.
# Keep the endpoint token only in Railway/API environment. Never commit the real URL.
# This bridge calls the main API through API_URL + AGENT_API_KEY.
XIAOZHI_MCP_ENDPOINT=wss://api.xiaozhi.me/mcp/?token=replace-me
XIAOZHI_MCP_ORGANIZATION_ID=default
XIAOZHI_MCP_AGENT_ID=coevo
XIAOZHI_MCP_USER_ID=xiaozhi-device
XIAOZHI_MCP_USER_NAME=Smart speaker XiaoZhi
XIAOZHI_MCP_USER_EMAIL=
XIAOZHI_MCP_SESSION_PREFIX=xiaozhi
XIAOZHI_MCP_RECONNECT_SECONDS=8

# External client directory
# Keep this token only in the API/Railway environment. Never expose it to Next.js.
CLIENT_DIRECTORY_ENABLED=false
CLIENT_DIRECTORY_API_URL=https://your-system.example.com/api/clients
CLIENT_DIRECTORY_API_KEY=replace-me
CLIENT_DIRECTORY_AUTH_HEADER=Authorization
CLIENT_DIRECTORY_AUTH_SCHEME=Bearer
CLIENT_DIRECTORY_EXTERNAL_ID_FIELD=id
CLIENT_DIRECTORY_NAME_FIELD=name
# Optional JSON path when the API returns nested lists, e.g. data.clients
CLIENT_DIRECTORY_ITEMS_PATH=
CLIENT_DIRECTORY_SYNC_ENABLED=true
CLIENT_DIRECTORY_SYNC_HOURS=6,14
CLIENT_DIRECTORY_SYNC_INTERVAL_SECONDS=300
